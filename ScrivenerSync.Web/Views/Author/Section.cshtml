@model SectionViewModel
@{ ViewData["Title"] = Model.Section.Title; }

<h2>@Model.Section.Title</h2>
<p style="color:#888">@Model.Section.ScrivenerStatus | Read by @Model.ReadCount reader(s)</p>

<div style="background:white; padding:24px; border:1px solid #eee; margin-bottom:32px">
    @Html.Raw(Model.Section.HtmlContent ?? "<p><em>No content.</em></p>")
</div>

<h3>Comments (@Model.Comments.Count)</h3>
@foreach (var c in Model.Comments)
{
    <div style="border-left:3px solid @(c.Visibility == Visibility.Private ? "#f0ad4e" : "#2a6496"); padding:12px; margin-bottom:12px">
        <strong>@c.AuthorId</strong>
        @if (c.Visibility == Visibility.Private) { <span style="color:#f0ad4e">[Private]</span> }
        <span style="color:#888; font-size:12px">@c.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
        @if (c.IsSoftDeleted)
        {
            <p style="color:#888; font-style:italic">This comment has been removed.</p>
        }
        else
        {
            <p>@c.Body</p>
        }
    </div>
}
