<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ScrivenerSync</title>
    <style>
        body { font-family: Georgia, serif; max-width: 1100px; margin: 0 auto; padding: 20px; background: #fafaf8; color: #1a1a1a; }
        nav { border-bottom: 1px solid #ddd; padding-bottom: 12px; margin-bottom: 24px; display: flex; gap: 20px; align-items: center; }
        nav a { text-decoration: none; color: #2a6496; }
        nav a:hover { text-decoration: underline; }
        .btn { display: inline-block; padding: 8px 16px; background: #2a6496; color: white; border: none; cursor: pointer; text-decoration: none; font-size: 14px; }
        .btn-sm { padding: 4px 10px; font-size: 12px; }
        .btn-danger { background: #c0392b; }
        .btn-secondary { background: #888; }
        .alert-success { background: #d4edda; border: 1px solid #c3e6cb; padding: 10px; margin-bottom: 16px; }
        .alert-error { background: #f8d7da; border: 1px solid #f5c6cb; padding: 10px; margin-bottom: 16px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #eee; }
        th { background: #f0f0ee; font-weight: bold; }
    </style>
</head>
<body>
    <nav>
        <strong>ScrivenerSync</strong>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Author" asp-action="Dashboard">Dashboard</a>
            <a asp-controller="Reader" asp-action="Index">Reader View</a>
            <a asp-controller="Author" asp-action="Readers">Readers</a>
            <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" style="background:none;border:none;color:#2a6496;cursor:pointer;padding:0">Log out (@User.Identity.Name)</button>
            </form>
        }
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error">@TempData["Error"]</div>
    }

    @RenderBody()
</body>
</html>
