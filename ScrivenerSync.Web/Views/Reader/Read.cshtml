@model ReadingViewModel
@{ ViewData["Title"] = Model.Section.Title; }

<div style="display:flex; gap:32px">
    <aside style="width:200px; flex-shrink:0">
        <h4>Contents</h4>
        <ul style="list-style:none; padding:0">
            @foreach (var s in Model.TableOfContents)
            {
                <li style="margin-bottom:8px">
                    <a asp-action="Read" asp-route-id="@s.Id"
                       style="@(s.Id == Model.Section.Id ? "font-weight:bold" : "")">@s.Title</a>
                </li>
            }
        </ul>
    </aside>

    <main style="flex:1">
        <h2>@Model.Section.Title</h2>
        <div style="background:white; padding:24px; border:1px solid #eee; margin-bottom:32px; line-height:1.8">
            @Html.Raw(Model.Section.HtmlContent ?? "<p><em>No content.</em></p>")
        </div>

        <h3>Comments</h3>
        @foreach (var c in Model.Comments)
        {
            <div style="border-left:3px solid #2a6496; padding:12px; margin-bottom:12px">
                @if (c.IsSoftDeleted)
                {
                    <p style="color:#888; font-style:italic">This comment has been removed.</p>
                }
                else
                {
                    <p><strong>Reader</strong> <span style="color:#888; font-size:12px">@c.CreatedAt.ToString("dd MMM yyyy")</span></p>
                    <p>@c.Body</p>
                    <form asp-action="AddComment" method="post" style="margin-top:8px">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SectionId" value="@Model.Section.Id" />
                        <input type="hidden" name="ParentCommentId" value="@c.Id" />
                        <input type="text" name="Body" placeholder="Reply..." style="width:80%; padding:6px" />
                        <button type="submit" class="btn btn-sm">Reply</button>
                    </form>
                }
            </div>
        }

        <div style="margin-top:24px; background:#f8f8f8; padding:16px; border:1px solid #eee">
            <h4>Add a comment</h4>
            <form asp-action="AddComment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="SectionId" value="@Model.Section.Id" />
                <textarea name="Body" rows="4" style="width:100%; padding:8px" placeholder="Your comment..."></textarea>
                <div style="margin-top:8px; display:flex; gap:16px; align-items:center">
                    <label><input type="checkbox" name="IsPrivate" /> Private (only you and the author can see this)</label>
                    <button type="submit" class="btn">Post Comment</button>
                </div>
            </form>
        </div>
    </main>
</div>
