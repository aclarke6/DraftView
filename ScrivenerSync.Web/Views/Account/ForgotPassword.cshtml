@model ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; }

<div class="login-wrap">
    <div class="login-header">
        <h1>Reset your password</h1>
        <p>Enter your email and we will send you a reset link.</p>
    </div>
    <div class="card">
        <div class="card__body">
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert--error"
                     style="margin-bottom:var(--space-5);"></div>
                <div class="form-group">
                    <label asp-for="Email">Email address</label>
                    <input asp-for="Email" type="email" autocomplete="email" />
                </div>
                <button type="submit" class="btn btn--primary" style="width:100%;">
                    Send reset link
                </button>
            </form>
        </div>
    </div>
    <div style="text-align:center; margin-top:var(--space-5);">
        <a asp-action="Login" style="font-size:var(--text-sm);">Back to sign in</a>
    </div>
</div>
