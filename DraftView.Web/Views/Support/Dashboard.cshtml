@model DraftView.Web.Models.SupportDashboardViewModel

@{
    ViewData["Title"] = "System Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">System Dashboard</h1>
        <p class="page-subtitle">System support operations and service status</p>
    </div>
</div>

<p>
    <a asp-action="Readers">View readers</a>
</p>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-card__label">System Status</div>
        <div class="stat-card__value">@Model.SystemStatus</div>
        <div class="stat-card__sub">Current platform state</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Active Authors</div>
        <div class="stat-card__value">@Model.ActiveAuthors</div>
        <div class="stat-card__sub">Author accounts currently active</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Active Readers</div>
        <div class="stat-card__value">@Model.ActiveReaders</div>
        <div class="stat-card__sub">Reader accounts currently active</div>
    </div>
</div>

<div class="dashboard-grid">
    <section class="card">
        <div class="card__header">
            <span class="card__title">User Account Management</span>
        </div>
        <div class="card__body">
            <p class="support-dashboard__intro">
                Manage platform users at system level. This area is for operational administration, not author workspace management.
            </p>

            <ul class="support-dashboard__list">
                <li>Invite author</li>
                <li>Force password reset email</li>
                <li>Update user email</li>
                <li>Change user display name</li>
                <li>Change user roles</li>
                <li>Activate user</li>
                <li>Deactivate user</li>
                <li>Soft delete user</li>
                <li>Review created, activated, login, notification, and soft delete timestamps</li>
            </ul>
        </div>
    </section>

    <section class="card">
        <div class="card__header">
            <span class="card__title">Support Messages</span>
        </div>
        <div class="card__body">

            @if (Model.ActiveMessage != null)
            {
                <div class="support-messages__active">
                    <p class="support-messages__active-text"><strong>@Model.ActiveMessage.Message</strong></p>
                    <p class="support-messages__active-meta">
                        <span class="support-messages__badge support-messages__badge--@Model.ActiveMessage.Severity.ToString().ToLower()">@Model.ActiveMessage.Severity</span>
                        <span>@Model.ActiveMessage.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                    </p>
                    <form method="post" asp-action="RevokeMessage">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="messageId" value="@Model.ActiveMessage.Id" />
                        <button type="submit" class="btn btn--danger">Revoke</button>
                    </form>
                </div>
            }
            else
            {
                <p class="support-messages__none">No active system message.</p>
            }

            <form method="post" asp-action="PostMessage" class="support-messages__form">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" class="form-control" required maxlength="500" rows="3"
                              placeholder="Enter system state message..."></textarea>
                </div>
                <div class="form-group">
                    <label for="severity">Severity</label>
                    <select id="severity" name="severity" class="form-control">
                        <option value="0" selected>Info</option>
                        <option value="1">Warning</option>
                        <option value="2">Critical</option>
                    </select>
                </div>
                <button type="submit" class="btn btn--primary">Post Message</button>
            </form>

            @if (Model.MessageHistory.Any())
            {
                <table class="support-messages__history">
                    <thead>
                        <tr>
                            <th>Message</th>
                            <th>Severity</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Deactivated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var msg in Model.MessageHistory)
                        {
                            <tr class="@(!msg.IsActive ? "support-messages__row--revoked" : "")">
                                <td>@msg.Message</td>
                                <td>@msg.Severity</td>
                                <td>@(msg.IsActive ? "Active" : "Revoked")</td>
                                <td>@msg.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@(msg.DeactivatedAt.HasValue ? msg.DeactivatedAt.Value.ToString("dd MMM yyyy HH:mm") : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="support-messages__none">No message history.</p>
            }

        </div>
    </section>
</div>