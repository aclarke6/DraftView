@model DesktopChapterReadViewModel
@using DraftView.Domain.Enumerations
@{
    ViewData["Title"] = Model.Chapter.Title;

    Guid? editCommentId = null;
    var editCommentIdRaw = Context.Request.Query["editCommentId"].ToString();

    if (Guid.TryParse(editCommentIdRaw, out var parsedEditCommentId))
    {
        editCommentId = parsedEditCommentId;
    }

@Html.AntiForgeryToken()
}

<div class="reader-page"
     data-prose-font="@Model.ProseFont"
     data-prose-font-size="@Model.ProseFontSize">

    <button type="button"
            class="reader__contents-toggle"
            id="readerContentsToggle"
            aria-expanded="false"
            aria-controls="readerContentsPanel">
        Contents
    </button>

    <div id="readerContentsPanel" class="reader__contents">
        @if (Model.BookContents is not null)
        {
            <div class="reader__contents-header">
                <a asp-action="Index" class="reader__contents-link reader__contents-link--chapter">@Model.ProjectName</a>
                <a asp-action="Browse"
                   asp-route-id="@Model.BookContents.TopLevelSection.Id"
                   class="reader__contents-link reader__contents-link--chapter">&rsaquo; @Model.BookContents.TopLevelSection.Title</a>
            </div>
            <hr class="reader__contents-divider" />
        }

        <div class="reader__contents-section">
            <div class="reader__contents-label">This chapter</div>
            @foreach (var item in Model.Scenes)
            {
                <a href="#scene-@item.Scene.Id" class="reader__contents-link">@item.Scene.Title@(item.CurrentVersionNumber.HasValue ? $" (v{item.CurrentVersionNumber.Value})" : string.Empty)</a>
            }
            <a href="#chapter-comments"
                   class="reader__contents-link reader__contents-link--muted">
                @Icons.Edit() Chapter Comments
            </a>
        </div>

        @if (Model.BookContents is not null && Model.BookContents.Groups.Any())
        {
            <hr class="reader__contents-divider" />
            <div class="reader__contents-section">
                <div class="reader__contents-label">Other chapters</div>

                @foreach (var group in Model.BookContents.Groups)
                {
                    @if (!string.IsNullOrEmpty(group.Heading))
                    {
                        <div class="reader__contents-subheading">@group.Heading</div>
                    }

                    @foreach (var sub in group.SubGroups)
                    {
                        @if (!string.IsNullOrEmpty(sub.Heading))
                        {
                            <div class="reader__contents-subheading reader__contents-subheading--nested">@sub.Heading</div>
                        }

                        @if (sub.ChapterSection is not null)
                        {
                            <a asp-action="Read"
                                   asp-route-id="@sub.ChapterSection.Id"
                                   class="reader__contents-link @(sub.ChapterSection.Id == Model.Chapter.Id ? "reader__contents-link--active" : "") reader__contents-link--indented">
                                @sub.ChapterSection.Title
                            </a>
                        }
                    }

                    @if (group.ChapterSection is not null)
                    {
                        <a asp-action="Read"
                               asp-route-id="@group.ChapterSection.Id"
                               class="reader__contents-link @(group.ChapterSection.Id == Model.Chapter.Id ? "reader__contents-link--active" : "")">
                            @group.ChapterSection.Title
                        </a>
                    }
                }
            </div>
        }
    </div>

    <div class="chapter-layout">
        <aside class="chapter-sidebar">
            @if (Model.BookContents is not null)
            {
                <div class="chapter-sidebar__header">
                    <a asp-action="Index" class="chapter-sidebar__link chapter-sidebar__link--chapter">@Model.ProjectName</a>
                    <a asp-action="Browse"
                       asp-route-id="@Model.BookContents.TopLevelSection.Id"
                       class="chapter-sidebar__link chapter-sidebar__link--chapter">&rsaquo; @Model.BookContents.TopLevelSection.Title</a>
                </div>
                <hr class="chapter-sidebar__divider" />
            }

            <div class="chapter-sidebar__label">This chapter</div>
            @foreach (var item in Model.Scenes)
            {
                <a href="#scene-@item.Scene.Id" class="chapter-sidebar__link">@item.Scene.Title@(item.CurrentVersionNumber.HasValue ? $" (v{item.CurrentVersionNumber.Value})" : string.Empty)</a>
            }

            <a href="#chapter-comments"
                   class="chapter-sidebar__link chapter-sidebar__link--muted chapter-sidebar__link--comments">
                @Icons.Edit() Chapter Comments
            </a>

            @if (Model.BookContents is not null && Model.BookContents.Groups.Any())
            {
                <hr class="chapter-sidebar__divider" />
                <div class="chapter-sidebar__label">Other chapters</div>

                @foreach (var group in Model.BookContents.Groups)
                {
                    @if (!string.IsNullOrEmpty(group.Heading))
                    {
                        <div class="chapter-sidebar__subheading">@group.Heading</div>
                    }

                    @foreach (var sub in group.SubGroups)
                    {
                        @if (!string.IsNullOrEmpty(sub.Heading))
                        {
                            <div class="chapter-sidebar__subheading chapter-sidebar__subheading--nested">@sub.Heading</div>
                        }

                        @if (sub.ChapterSection is not null)
                        {
                            <a asp-action="Read"
                                   asp-route-id="@sub.ChapterSection.Id"
                                   class="chapter-sidebar__link chapter-sidebar__link--indented @(sub.ChapterSection.Id == Model.Chapter.Id ? "chapter-sidebar__link--active" : "")">
                                @sub.ChapterSection.Title
                            </a>
                        }
                    }

                    @if (group.ChapterSection is not null)
                    {
                        <a asp-action="Read"
                               asp-route-id="@group.ChapterSection.Id"
                               class="chapter-sidebar__link @(group.ChapterSection.Id == Model.Chapter.Id ? "chapter-sidebar__link--active" : "")">
                            @group.ChapterSection.Title
                        </a>
                    }
                }
            }
        </aside>

        <main class="chapter-main">
            @if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="validation-summary-errors" role="alert">
                    @errorMessage
                </div>
            }
            
            @if (Model.Breadcrumb.Any())
            {
                <div class="chapter-breadcrumb">
                    @for (int i = 0; i < Model.Breadcrumb.Count; i++)
                    {
                        @Model.Breadcrumb[i]
                        if (i < Model.Breadcrumb.Count - 1)
                        {
                            <span class="chapter-breadcrumb__sep">&rsaquo;</span>
                        }
                    }
                </div>
            }

            <h2 class="chapter-title">@Model.Chapter.Title</h2>

            @foreach (var item in Model.Scenes)
            {
                var roots = item.Comments.Where(c => c.Comment.ParentCommentId == null).ToList();
                var replies = item.Comments.Where(c => c.Comment.ParentCommentId != null)
                    .GroupBy(c => c.Comment.ParentCommentId!.Value)
                    .ToDictionary(g => g.Key, g => g.ToList());

                <div class="scene-block"
                     id="scene-@item.Scene.Id"
                     data-section-id="@item.Scene.Id"
                     data-section-version-id="@(item.CurrentSectionVersionId?.ToString() ?? string.Empty)"
                     data-resume-capture-text="@item.ResumeCaptureText"
                     data-resume-restore-has-target="@item.HasResumeRestoreTarget.ToString().ToLowerInvariant()"
                     data-resume-restore-start-offset="@(item.ResumeRestoreStartOffset?.ToString() ?? string.Empty)"
                     data-resume-restore-end-offset="@(item.ResumeRestoreEndOffset?.ToString() ?? string.Empty)"
                     data-resume-restore-status="@(item.ResumeRestoreStatus?.ToString() ?? string.Empty)"
                     data-resume-restore-confidence="@(item.ResumeRestoreConfidenceScore?.ToString() ?? string.Empty)"
                     data-resume-restore-match-method="@(item.ResumeRestoreMatchMethod?.ToString() ?? string.Empty)">
                    <div class="scene-prose">
                        @if (Model.Chapter.IsLocked)
                        {
                            <div class="lock-notice">
                                <p>The author is currently revising this chapter.</p>
                            </div>
                        }

                        <h4 class="scene-heading">@item.Scene.Title</h4>

                        @if (item.ShowUpdateBanner && item.CurrentVersionNumber.HasValue)
                        {
                            <div class="update-banner" data-section-id="@item.Scene.Id" data-version="@item.CurrentVersionNumber">
                                <div class="update-banner__content">
                                    <span class="update-banner__version">
                                        Updated — version @item.CurrentVersionNumber
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(item.AiSummary))
                                    {
                                        <span class="update-banner__summary">@item.AiSummary</span>
                                    }
                                </div>
                                <button type="button" class="update-banner__dismiss" aria-label="Dismiss update notice">
                                    Dismiss
                                </button>
                            </div>
                        }

                        @if (item.UpdatedSinceLastRead)
                        {
                            <div class="scene-updated-notice">
                                Updated since you last read
                            </div>
                        }

                        <div class="scene-prose-shell">
                            <div class="scene-prose-content prose">
                                @if (item.HasDiff)
                                {
                                    @foreach (var para in item.DiffParagraphs)
                                    {
                                        if (para.Type == DiffResultType.Added)
                                        {
                                            <div class="diff-para diff-para--added">@Html.Raw(para.Html)</div>
                                        }
                                        else if (para.Type == DiffResultType.Removed)
                                        {
                                            <div class="diff-para diff-para--removed"></div>
                                        }
                                        else
                                        {
                                            @Html.Raw(para.Html)
                                        }
                                    }
                                }
                                else
                                {
                                    @Html.Raw(item.ResolvedHtmlContent ?? "<p><em>The author has not added content to this scene yet.</em></p>")
                                }
                            </div>
                        </div>
                    </div>

                    <div class="scene-comments">
                        <div class="scene-comments-label">Comments</div>

                        @foreach (var c in roots)
                        {
                            <div class="comment-box @(c.Comment.Visibility == Visibility.Private ? "comment-box--private" : "")">
                                <div class="comment-box__meta">
                                    <strong>@c.AuthorDisplayName</strong>
                                    <span class="comment-box__date">@c.Comment.CreatedAt.ToString("dd MMM")</span>
                                    @if (c.Comment.Visibility == Visibility.Private)
                                    {
                                        <span class="comment-box__private">[Private]</span>
                                    }

                                    <span class="comment-box__actions">
                                        @if (c.CanEdit)
                                        {
                                            <a asp-action="Read"
                                                   asp-route-id="@Model.Chapter.Id"
                                                   asp-route-editCommentId="@c.Comment.Id"
                                                   class="comment-action-btn"
                                                   title="Edit"
                                                   aria-label="Edit comment">
                                                @Icons.Edit()
                                            </a>
                                        }

                                        @if (c.CanDelete || c.UseModeratorDelete)
                                        {
                                            <form asp-action="@(c.UseModeratorDelete ? "ModerateDeleteComment" : "DeleteComment")"
                                                  method="post"
                                                  class="comment-delete-form"
                                                  data-delete-mode="@(c.UseModeratorDelete ? "moderator" : "normal")"
                                                  data-has-children="@(c.HasChildren ? "true" : "false")">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="commentId" value="@c.Comment.Id" />
                                                <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                                <button type="submit"
                                                        class="comment-action-btn comment-action-btn--danger"
                                                        title="@(c.UseModeratorDelete ? "Moderator delete" : "Delete")"
                                                        aria-label="@(c.UseModeratorDelete ? "Moderator delete comment" : "Delete comment")">
                                                    @Icons.Delete()
                                                </button>
                                            </form>
                                        }
                                    </span>

                                    @if (Model.CurrentUserIsModerator)
                                    {
                                        <form asp-controller="Reader" asp-action="SetCommentStatus" method="post" style="display:inline; margin-left:auto;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="commentId" value="@c.Comment.Id" />
                                            <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                            <input type="hidden" name="sceneId" value="@item.Scene.Id" />
                                            <select name="status" onchange="this.form.submit()"
                                                    style="font-size:var(--text-xs); padding:2px 4px; border-radius:var(--radius-sm);
                                                           border:1px solid var(--color-border); background:white; cursor:pointer;">
                                                @foreach (var s in Enum.GetValues<CommentStatus>())
                                                {
                                                    <option value="@s" selected="@(c.Comment.Status == s)">@s</option>
                                                }
                                            </select>
                                        </form>
                                    }
                                </div>

                                @if (editCommentId == c.Comment.Id)
                                {
                                    <form asp-action="EditComment" method="post" class="comment-box__reply-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commentId" value="@c.Comment.Id" />
                                        <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                        <input type="text" name="body" value="@c.Comment.Body" class="comment-box__reply-input" />
                                        <button type="submit"
                                                class="comment-action-btn comment-action-btn--primary"
                                                title="Save"
                                                aria-label="Save comment">
                                            @Icons.Save()
                                        </button>

                                        <a asp-action="Read"
                                               asp-route-id="@Model.Chapter.Id"
                                               class="comment-action-btn"
                                               title="Cancel"
                                               aria-label="Cancel edit">
                                            @Icons.Cancel()
                                        </a>
                                    </form>
                                }
                                else
                                {
                                    <p class="comment-box__body">@c.Comment.Body</p>

                                    <form asp-action="AddComment" method="post" class="comment-box__reply-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                        <input type="hidden" name="ParentCommentId" value="@c.Comment.Id" />
                                        <input type="text" name="Body" placeholder="Reply..." class="comment-box__reply-input" />
                                        <button type="submit"
                                                class="comment-action-btn comment-action-btn--reply"
                                                title="Reply"
                                                aria-label="Reply to comment">
                                            @Icons.Reply()
                                        </button>
                                    </form>
                                }
                            </div>

                            @if (replies.TryGetValue(c.Comment.Id, out var childReplies))
                            {
                                @foreach (var r in childReplies)
                                {
                                    <div class="comment-box comment-box--reply @(r.Comment.Visibility == Visibility.Private ? "comment-box--private" : "")">

                                        <div class="comment-box__meta">
                                            <strong>@r.AuthorDisplayName</strong>
                                            <span class="comment-box__date">@r.Comment.CreatedAt.ToString("dd MMM")</span>
                                            @if (r.Comment.Visibility == Visibility.Private)
                                            {
                                                <span class="comment-box__private">[Private]</span>
                                            }

                                            <span class="comment-box__actions">
                                                @if (r.CanEdit)
                                                {
                                                    <a asp-action="Read"
                                                           asp-route-id="@Model.Chapter.Id"
                                                           asp-route-editCommentId="@r.Comment.Id"
                                                           class="comment-action-btn"
                                                           title="Edit"
                                                           aria-label="Edit reply">
                                                        @Icons.Edit()
                                                    </a>
                                                }

                                                @if (r.CanDelete || r.UseModeratorDelete)
                                                {
                                                    <form asp-action="@(r.UseModeratorDelete ? "ModerateDeleteComment" : "DeleteComment")"
                                                          method="post"
                                                          class="comment-delete-form"
                                                          data-delete-mode="@(r.UseModeratorDelete ? "moderator" : "normal")"
                                                          data-has-children="@(r.HasChildren ? "true" : "false")">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commentId" value="@r.Comment.Id" />
                                                        <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                                        <button type="submit"
                                                                class="comment-action-btn comment-action-btn--danger"
                                                                title="@(r.UseModeratorDelete ? "Moderator delete" : "Delete")"
                                                                aria-label="@(r.UseModeratorDelete ? "Moderator delete reply" : "Delete reply")">
                                                            @Icons.Delete()
                                                        </button>
                                                    </form>
                                                }
                                            </span>
                                        </div>

                                        @if (editCommentId == r.Comment.Id)
                                        {
                                            <form asp-action="EditComment" method="post" class="comment-box__reply-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="commentId" value="@r.Comment.Id" />
                                                <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                                <input type="text" name="body" value="@r.Comment.Body" class="comment-box__reply-input" />
                                                <button type="submit"
                                                        class="comment-action-btn comment-action-btn--primary"
                                                        title="Save"
                                                        aria-label="Save comment">
                                                    @Icons.Save()
                                                </button>

                                                <a asp-action="Read"
                                                       asp-route-id="@Model.Chapter.Id"
                                                       class="comment-action-btn"
                                                       title="Cancel"
                                                       aria-label="Cancel edit">
                                                    @Icons.Cancel()
                                                </a>
                                            </form>
                                        }
                                        else
                                        {
                                            <p class="comment-box__body">@r.Comment.Body</p>

                                            <form asp-action="AddComment" method="post" class="comment-box__reply-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                                <input type="hidden" name="ParentCommentId" value="@c.Comment.Id" />
                                                <input type="text" name="Body" placeholder="Reply..." class="comment-box__reply-input" />
                                                <button type="submit"
                                                        class="comment-action-btn comment-action-btn--reply"
                                                        title="Reply"
                                                        aria-label="Reply to comment">
                                                    @Icons.Reply()
                                                </button>
                                            </form>
                                        }
                                        
                                    </div>
                                }
                            }
                        }

                        <div class="add-comment-mini">
                            <form asp-action="AddComment" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                <textarea name="Body" rows="3" placeholder="Comment on @item.Scene.Title..."></textarea>

                                <div class="add-comment-mini__actions">
                                    <label class="add-comment-mini__private">
                                        <input type="checkbox" name="IsPrivate" />
                                        Private
                                    </label>
                                    <button type="submit"
                                            class="comment-action-btn comment-action-btn--primary"
                                            title="Post comment"
                                            aria-label="Post comment">
                                        @Icons.Send()
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }

            <div class="chapter-comments" id="chapter-comments">
                <h3>Chapter Comments</h3>
                <p class="chapter-comments__intro">Use chapter comments for overall impressions of the chapter as a whole.</p>

                @{
                    var chapterRoots = Model.ChapterComments.Where(c => c.Comment.ParentCommentId == null).ToList();
                    var chapterReplies = Model.ChapterComments.Where(c => c.Comment.ParentCommentId != null)
                        .GroupBy(c => c.Comment.ParentCommentId!.Value)
                        .ToDictionary(g => g.Key, g => g.ToList());
                }

                @foreach (var c in chapterRoots)
                {
                    <div class="chapter-comment @(c.Comment.Visibility == Visibility.Private ? "chapter-comment--private" : "")">
                        <div class="chapter-comment__meta">
                            <strong>@c.AuthorDisplayName</strong>
                            <span class="chapter-comment__date">@c.Comment.CreatedAt.ToString("dd MMM yyyy")</span>
                            @if (c.Comment.Visibility == Visibility.Private)
                            {
                                <span class="chapter-comment__private">[Private]</span>
                            }

                            <span class="chapter-comment__actions">
                                @if (c.CanEdit)
                                {
                                    <a asp-action="Read"
                                           asp-route-id="@Model.Chapter.Id"
                                           asp-route-editCommentId="@c.Comment.Id"
                                           class="comment-action-btn"
                                           title="Edit"
                                           aria-label="Edit chapter comment">
                                        @Icons.Edit()
                                    </a>
                                }

                                @if (c.CanDelete || c.UseModeratorDelete)
                                {
                                    <form asp-action="@(c.UseModeratorDelete ? "ModerateDeleteComment" : "DeleteComment")"
                                          method="post"
                                          class="comment-delete-form"
                                          data-delete-mode="@(c.UseModeratorDelete ? "moderator" : "normal")"
                                          data-has-children="@(c.HasChildren ? "true" : "false")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commentId" value="@c.Comment.Id" />
                                        <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                        <button type="submit"
                                                class="comment-action-btn comment-action-btn--danger"
                                                title="@(c.UseModeratorDelete ? "Moderator delete" : "Delete")"
                                                aria-label="@(c.UseModeratorDelete ? "Moderator delete comment" : "Delete comment")">
                                            @Icons.Delete()
                                        </button>
                                    </form>
                                }
                            </span>

                            @if (Model.CurrentUserIsModerator)
                            {
                                <form asp-controller="Reader" asp-action="SetCommentStatus" method="post" style="display:inline; margin-left:auto;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.Comment.Id" />
                                    <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                    <input type="hidden" name="sceneId" value="@Model.Chapter.Id" />
                                    <select name="status" onchange="this.form.submit()"
                                            style="font-size:var(--text-xs); padding:2px 4px; border-radius:var(--radius-sm);
                                                   border:1px solid var(--color-border); background:white; cursor:pointer;">
                                        @foreach (var s in Enum.GetValues<CommentStatus>())
                                        {
                                            <option value="@s" selected="@(c.Comment.Status == s)">@s</option>
                                        }
                                    </select>
                                </form>
                            }
                        </div>

                        @if (editCommentId == c.Comment.Id)
                        {
                            <form asp-action="EditComment" method="post" class="chapter-comment__reply-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="commentId" value="@c.Comment.Id" />
                                <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                <input type="text" name="body" value="@c.Comment.Body" class="chapter-comment__reply-input" />
                                <button type="submit"
                                        class="comment-action-btn comment-action-btn--primary"
                                        title="Save"
                                        aria-label="Save comment">
                                    @Icons.Save()
                                </button>

                                <a asp-action="Read"
                                       asp-route-id="@Model.Chapter.Id"
                                       class="comment-action-btn"
                                       title="Cancel"
                                       aria-label="Cancel edit">
                                    @Icons.Cancel()
                                </a>
                            </form>
                        }
                        else
                        {
                            <p class="chapter-comment__body">@c.Comment.Body</p>

                            <form asp-action="AddComment" method="post" class="chapter-comment__reply-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />
                                <input type="hidden" name="ParentCommentId" value="@c.Comment.Id" />
                                <input type="text" name="Body" placeholder="Reply..." class="chapter-comment__reply-input" />
                                <button type="submit"
                                        class="comment-action-btn comment-action-btn--reply"
                                        title="Reply"
                                        aria-label="Reply to comment">
                                    @Icons.Reply()
                                </button>
                            </form>
                        }
                    </div>

                    @if (chapterReplies.TryGetValue(c.Comment.Id, out var childReplies))
                    {
                        @foreach (var r in childReplies)
                        {
                            <div class="chapter-comment chapter-comment--reply @(r.Comment.Visibility == Visibility.Private ? "chapter-comment--private" : "")">
                                <div class="chapter-comment__meta">
                                    <strong>@r.AuthorDisplayName</strong>
                                    <span class="chapter-comment__date">@r.Comment.CreatedAt.ToString("dd MMM yyyy")</span>
                                    @if (r.Comment.Visibility == Visibility.Private)
                                    {
                                        <span class="chapter-comment__private">[Private]</span>
                                    }

                                    <span class="chapter-comment__actions">
                                        @if (r.CanEdit)
                                        {
                                            <a asp-action="Read"
                                                   asp-route-id="@Model.Chapter.Id"
                                                   asp-route-editCommentId="@r.Comment.Id"
                                                   class="comment-action-btn"
                                                   title="Edit"
                                                   aria-label="Edit chapter reply">
                                                @Icons.Edit()
                                            </a>
                                        }

                                        @if (r.CanDelete || r.UseModeratorDelete)
                                        {
                                            <form asp-action="@(r.UseModeratorDelete ? "ModerateDeleteComment" : "DeleteComment")"
                                                  method="post"
                                                  class="comment-delete-form"
                                                  data-delete-mode="@(r.UseModeratorDelete ? "moderator" : "normal")"
                                                  data-has-children="@(r.HasChildren ? "true" : "false")">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="commentId" value="@r.Comment.Id" />
                                                <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                                <button type="submit"
                                                        class="comment-action-btn comment-action-btn--danger"
                                                        title="@(r.UseModeratorDelete ? "Moderator delete" : "Delete")"
                                                        aria-label="@(r.UseModeratorDelete ? "Moderator delete reply" : "Delete reply")">
                                                    @Icons.Delete()
                                                </button>
                                            </form>
                                        }
                                    </span>
                                </div>

                                @if (editCommentId == r.Comment.Id)
                                {
                                    <form asp-action="EditComment" method="post" class="chapter-comment__reply-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commentId" value="@r.Comment.Id" />
                                        <input type="hidden" name="chapterId" value="@Model.Chapter.Id" />
                                        <input type="text" name="body" value="@r.Comment.Body" class="chapter-comment__reply-input" />
                                        <button type="submit"
                                                class="comment-action-btn comment-action-btn--primary"
                                                title="Save"
                                                aria-label="Save comment">
                                            @Icons.Save()
                                        </button>

                                        <a asp-action="Read"
                                               asp-route-id="@Model.Chapter.Id"
                                               class="comment-action-btn"
                                               title="Cancel"
                                               aria-label="Cancel edit">
                                            @Icons.Cancel()
                                        </a>
                                    </form>
                                }
                                else
                                {
                                    <p class="chapter-comment__body">@r.Comment.Body</p>

                                    <form asp-action="AddComment" method="post" class="chapter-comment__reply-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />
                                        <input type="hidden" name="ParentCommentId" value="@c.Comment.Id" />
                                        <input type="text" name="Body" placeholder="Reply..." class="chapter-comment__reply-input" />
                                        <button type="submit"
                                                class="comment-action-btn comment-action-btn--reply"
                                                title="Reply"
                                                aria-label="Reply to comment">
                                            @Icons.Reply()
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    }
                }

                <div class="chapter-comment-form">
                    <h4 class="chapter-comment-form__title">Add a chapter comment</h4>

                    <form asp-action="AddComment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />

                        <textarea name="Body"
                                  rows="4"
                                  placeholder="Your overall thoughts on this chapter..."
                                  class="chapter-comment-form__textarea"></textarea>

                        <div class="chapter-comment-form__actions">
                            <label class="chapter-comment-form__private">
                                <input type="checkbox" name="IsPrivate" />
                                Private - only you and the author can see this
                            </label>

                            <button type="submit"
                                    class="comment-action-btn comment-action-btn--primary"
                                    title="Post comment"
                                    aria-label="Post comment">
                                @Icons.Send()
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
    (function () {
        var key = 'scroll_chapter_@Model.Chapter.Id';
        var saved = localStorage.getItem(key);
        var sceneBlocks = Array.prototype.slice.call(document.querySelectorAll('.scene-block[data-section-id]'));

        function parseIntAttribute(element, name) {
            var value = element.getAttribute(name);
            if (!value) {
                return null;
            }

            var parsed = parseInt(value, 10);
            return Number.isNaN(parsed) ? null : parsed;
        }

        function buildCanonicalPoints(container) {
            var walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT);
            var points = [];
            var pendingWhitespace = null;

            while (walker.nextNode()) {
                var node = walker.currentNode;
                var text = node.nodeValue || '';

                for (var i = 0; i < text.length; i++) {
                    var character = text.charAt(i);
                    if (/\s/.test(character)) {
                        if (points.length > 0 && !pendingWhitespace) {
                            pendingWhitespace = { node: node, start: i, end: i + 1 };
                        }

                        continue;
                    }

                    if (pendingWhitespace) {
                        points.push(pendingWhitespace);
                        pendingWhitespace = null;
                    }

                    points.push({ node: node, start: i, end: i + 1 });
                }
            }

            return points;
        }

        function createCanonicalRange(container, startOffset, endOffset) {
            if (startOffset === null || endOffset === null || endOffset <= startOffset) {
                return null;
            }

            var points = buildCanonicalPoints(container);
            if (startOffset < 0 || endOffset > points.length) {
                return null;
            }

            var startPoint = points[startOffset];
            var endPoint = points[endOffset - 1];
            if (!startPoint || !endPoint) {
                return null;
            }

            var range = document.createRange();
            range.setStart(startPoint.node, startPoint.start);
            range.setEnd(endPoint.node, endPoint.end);
            return range;
        }

        function scrollToRange(range, fallbackElement) {
            var rect = range ? range.getBoundingClientRect() : fallbackElement.getBoundingClientRect();
            var targetY = window.scrollY + rect.top - (window.innerHeight * 0.33);
            window.scrollTo(0, Math.max(0, Math.floor(targetY)));
        }

        function restoreFromAnchor() {
            if (window.location.hash) {
                return false;
            }

            var targetScene = sceneBlocks.find(function (scene) {
                return scene.getAttribute('data-resume-restore-has-target') === 'true';
            });

            if (!targetScene) {
                return false;
            }

            var prose = targetScene.querySelector('.scene-prose-content');
            if (!prose) {
                scrollToRange(null, targetScene);
                return true;
            }

            var startOffset = parseIntAttribute(targetScene, 'data-resume-restore-start-offset');
            var endOffset = parseIntAttribute(targetScene, 'data-resume-restore-end-offset');
            var range = createCanonicalRange(prose, startOffset, endOffset);

            scrollToRange(range, targetScene);
            return true;
        }

        if (!restoreFromAnchor() && saved) {
            setTimeout(function () { window.scrollTo(0, parseInt(saved, 10)); }, 100);
        }

        var links = document.querySelectorAll('.chapter-sidebar .chapter-sidebar__link[href^="#"]');
        var sections = [];
        links.forEach(function (link) {
            var id = link.getAttribute('href').substring(1);
            var el = document.getElementById(id);
            if (el) {
                sections.push({ el: el, link: link });
            }
        });

        function updateActive() {
            var scrollY = window.scrollY + 120;
            var current = null;
            sections.forEach(function (s) {
                if (s.el.offsetTop <= scrollY) current = s;
            });

            links.forEach(function (l) {
                l.classList.remove('chapter-sidebar__link--active');
            });

            if (current) {
                current.link.classList.add('chapter-sidebar__link--active');
            }
        }

        var timer;
        window.addEventListener('scroll', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                localStorage.setItem(key, window.scrollY);
                updateActive();
            }, 150);
        });

        updateActive();
    })();

    (function () {
        var antiForgeryInput = document.querySelector('input[name="__RequestVerificationToken"]');
        var sceneBlocks = Array.prototype.slice.call(document.querySelectorAll('.scene-block[data-section-id]'));
        if (!antiForgeryInput || sceneBlocks.length === 0) {
            return;
        }

        var captureUrl = '/Reader/CaptureResumePosition';
        var selectionLength = 48;
        var contextLength = 120;
        var lastCaptureKey = '';
        var timer;

        function normalizeText(text) {
            return (text || '').replace(/\s+/g, ' ').trim();
        }

        function clamp(value, min, max) {
            return Math.max(min, Math.min(max, value));
        }

        async function hashText(text) {
            if (window.crypto && window.crypto.subtle && window.TextEncoder) {
                var bytes = new TextEncoder().encode(text);
                var digest = await window.crypto.subtle.digest('SHA-256', bytes);
                return Array.from(new Uint8Array(digest)).map(function (b) {
                    return b.toString(16).padStart(2, '0');
                }).join('');
            }

            return String(text.length) + ':' + text.substring(0, 32);
        }

        function trimSelectionBounds(text, start, end) {
            while (start < end && text.charAt(start) === ' ') {
                start++;
            }

            while (end > start && text.charAt(end - 1) === ' ') {
                end--;
            }

            return { start: start, end: end };
        }

        function buildPayload(sectionId, versionId, canonicalText, ratio, selectorHint) {
            var normalized = normalizeText(canonicalText);
            if (!normalized) {
                return null;
            }

            var focusIndex = Math.floor(clamp(ratio, 0, 0.9999) * normalized.length);
            var start = Math.max(0, focusIndex - Math.floor(selectionLength / 2));
            var end = Math.min(normalized.length, start + selectionLength);
            var bounds = trimSelectionBounds(normalized, start, end);
            start = bounds.start;
            end = bounds.end;

            if (end <= start) {
                return null;
            }

            var selectedText = normalized.slice(start, end);
            if (!selectedText) {
                return null;
            }

            var prefixStart = Math.max(0, start - contextLength);
            var suffixEnd = Math.min(normalized.length, end + contextLength);

            return {
                sectionId: sectionId,
                originalSectionVersionId: versionId || null,
                selectedText: selectedText,
                normalizedSelectedText: selectedText,
                prefixContext: normalized.slice(prefixStart, start),
                suffixContext: normalized.slice(end, suffixEnd),
                startOffset: start,
                endOffset: end,
                canonicalContentHash: '',
                selectedTextHash: '',
                htmlSelectorHint: selectorHint
            };
        }

        function getCurrentScene() {
            var focusY = window.scrollY + (window.innerHeight * 0.33);
            var current = null;

            sceneBlocks.forEach(function (scene) {
                var rect = scene.getBoundingClientRect();
                var top = window.scrollY + rect.top;
                if (top <= focusY) {
                    current = scene;
                }
            });

            return current || sceneBlocks[0];
        }

        async function capturePosition() {
            var scene = getCurrentScene();
            if (!scene) {
                return;
            }

            var sectionId = scene.getAttribute('data-section-id');
            var versionId = scene.getAttribute('data-section-version-id');
            var canonicalText = scene.getAttribute('data-resume-capture-text') || '';
            if (!sectionId || !canonicalText) {
                return;
            }

            var rect = scene.getBoundingClientRect();
            var top = window.scrollY + rect.top;
            var focusY = window.scrollY + (window.innerHeight * 0.33);
            var ratio = clamp((focusY - top) / Math.max(scene.offsetHeight, 1), 0, 0.9999);
            var payload = buildPayload(sectionId, versionId, canonicalText, ratio, '#' + scene.id);
            if (!payload) {
                return;
            }

            payload.selectedTextHash = await hashText(payload.normalizedSelectedText);
            payload.canonicalContentHash = await hashText(canonicalText);

            var captureKey = JSON.stringify([
                payload.sectionId,
                payload.originalSectionVersionId,
                payload.startOffset,
                payload.endOffset,
                payload.selectedText
            ]);
            if (captureKey === lastCaptureKey) {
                return;
            }

            lastCaptureKey = captureKey;

            fetch(captureUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryInput.value
                },
                body: JSON.stringify(payload)
            }).catch(function () {
                lastCaptureKey = '';
            });
        }

        window.addEventListener('scroll', function () {
            clearTimeout(timer);
            timer = setTimeout(capturePosition, 250);
        });

        window.addEventListener('beforeunload', capturePosition);
    })();

    (function () {
        var toggle = document.getElementById('readerContentsToggle');
        var panel = document.getElementById('readerContentsPanel');

        if (!toggle || !panel) {
            return;
        }

        toggle.addEventListener('click', function () {
            var isOpen = panel.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        panel.querySelectorAll('a[href^="#"]').forEach(function (link) {
            link.addEventListener('click', function () {
                panel.classList.remove('is-open');
                toggle.setAttribute('aria-expanded', 'false');
            });
        });
    })();

    (function () {
        var deleteForms = document.querySelectorAll('.comment-delete-form');

        deleteForms.forEach(function (form) {
            form.addEventListener('submit', function (event) {
                var mode = form.getAttribute('data-delete-mode');
                var hasChildren = form.getAttribute('data-has-children') === 'true';
                var message = '';

                if (mode === 'moderator') {
                    message = hasChildren
                        ? 'Moderator Delete: this will delete this comment and all replies beneath it. Continue?'
                        : 'Moderator Delete: this will delete this comment. Continue?';
                } else {
                    message = 'Delete this comment?';
                }

                if (!window.confirm(message)) {
                    event.preventDefault();
                }
            });
        });
    })();
</script>
