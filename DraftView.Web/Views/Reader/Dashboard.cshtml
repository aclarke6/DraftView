@model DraftView.Web.Models.ReaderDashboardViewModel
@{ ViewData["Title"] = "My Reading"; }

<!-- Atmosphere hero -->
<div class="site-hero reader-dashboard__hero" >
    <div class="site-hero__content">
        <div class="site-hero__title">Welcome back</div>
        <div class="site-hero__subtitle">
            @if (Model.ProjectName is not null)
            {
                @($"{Model.ReadChapters} of {Model.TotalChapters} chapters read")
            }
            else
            {
                @:No manuscript available yet
            }
        </div>
    </div>
</div>

<div class="reader-dashboard">

    @if (Model.ProjectName is null)
    {
        <div class="card">
            <div class="card__body reader-dashboard__empty-body">
                <p class="reader-dashboard__empty-text">
                    No manuscript is currently available for reading.
                </p>
                <p class="reader-dashboard__empty-note">
                    The author will notify you when chapters are ready.
                </p>
            </div>
        </div>
    }
    else
    {
        <!-- Progress bar -->
        <div class="card reader-dashboard__progress-card">
            <div class="card__body">
                <div class="reader-dashboard__progress-header">
                    <span class="reader-dashboard__progress-title">@Model.ProjectName</span>
                    <span class="reader-dashboard__progress-meta">@Model.ReadChapters / @Model.TotalChapters chapters</span>
                </div>
                @{
                    var pct = Model.TotalChapters > 0
                        ? (int)((double)Model.ReadChapters / Model.TotalChapters * 100)
                        : 0;
                }
                <div class="reader-dashboard__progress-track">
                    <div class="reader-dashboard__progress-fill" style="width:@(pct)%;"></div>
                </div>
            </div>
        </div>

        <!-- Chapter list -->
        <div class="card">
            <div class="card__body reader-dashboard__chapters-body">
                @if (!Model.PublishedChapters.Any())
                {
                    <p class="reader-dashboard__chapters-empty">No chapters published yet.</p>
                }
                else
                {
                    <div class="reader-dashboard__table-wrap">
                        <table class="reader-dashboard__table">
                            <thead>
                                <tr class="reader-dashboard__row">
                                    <th class="reader-dashboard__head">Chapter</th>
                                    <th class="reader-dashboard__head">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.PublishedChapters)
                                {
                                    <tr class="reader-dashboard__row">
                                        <td class="reader-dashboard__cell reader-dashboard__cell--chapter">
                                            <a asp-controller="Reader" asp-action="Read"
                                                   asp-route-id="@item.Chapter.Id" 
                                            class="reader-dashboard__chapter-link">
                                                   @item.Chapter.Title
                                            </a>
                                        </td>
                                        <td class="reader-dashboard__cell reader-dashboard__cell--status">
                                            @if (item.HasRead)
                                            {
                                                <span class="reader-dashboard__status reader-dashboard__status--read">Read</span>
                                            }
                                            else
                                            {
                                                <span class="reader-dashboard__status reader-dashboard__status--new">New</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

