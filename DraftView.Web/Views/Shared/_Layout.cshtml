<!--
_Layout page.
This is default layout for all pages. It includes the navigation bar, flash messages,
and footer. The main content of each page is rendered in the RenderBody() section.
All pages should use this layout unless they specify otherwise.
All css files are included here to ensure consistent styling across the site.
-->
@inject DraftView.Domain.Interfaces.Services.ISystemStateMessageService SystemStateMessageService
@inject DraftView.Domain.Interfaces.Repositories.IUserRepository UserRepository
@inject DraftView.Domain.Interfaces.Repositories.IUserPreferencesRepository UserPreferencesRepository

@{
    var theme = "Light";
    var proseFont = "SystemSerif";
    var proseFontSize = "Medium";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserEmail = User.Identity?.Name;
    var accountNavLabel = "Account settings";
    DraftView.Domain.Entities.User? currentUser = null;

    if (User.Identity?.IsAuthenticated == true && !string.IsNullOrWhiteSpace(currentUserId))
    {
        currentUser = await UserRepository.GetByIdAsync(
            Guid.Parse(currentUserId));
    }

    if (currentUser is null &&
        User.Identity?.IsAuthenticated == true &&
        !string.IsNullOrWhiteSpace(currentUserEmail))
    {
        currentUser = await UserRepository.GetByEmailAsync(currentUserEmail);
    }

    if (currentUser is not null)
    {
        if (!string.IsNullOrWhiteSpace(currentUser.DisplayName))
            accountNavLabel = currentUser.DisplayName;

        var prefs = await UserPreferencesRepository.GetByUserIdAsync(currentUser.Id);
        if (prefs is not null)
        {
            theme = prefs.DisplayTheme.ToString();
            proseFont = prefs.ProseFont.ToString();
            proseFontSize = prefs.ProseFontSize.ToString();
        }
    }

    var themeCss = theme == "Dark"
        ? "/css/DraftView.Dark.css"
        : "/css/DraftView.Light.css";

    ViewData["ProseFont"] = proseFont;
    ViewData["ProseFontSize"] = proseFontSize;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - DraftView" : "DraftView")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Merriweather:wght@400;700&family=Lato:wght@400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="@themeCss?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Core.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Settings.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Navigation.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Components.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.DesktopReader.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.MobileReader.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Dashboard.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Notifications.css?v=v2026-04-18-6" />
    <link rel="stylesheet" href="/css/DraftView.Mobile.css?v=v2026-04-18-6" />
    
    <link rel="icon" type="image/png" href="~/images/DraftView.Logo.web.png" />

    @{
        if (Context.Request.Query["debug"] == "css" ||
            Context.RequestServices.GetRequiredService<IWebHostEnvironment>().IsDevelopment())
        {
            <link rel="stylesheet" href="/css/DraftView.Debug.css?v=v2026-04-18-6" />
        }
    }
</head>

<body data-prose-font="@proseFont" data-prose-font-size="@proseFontSize">

    <!-- Navigation -->
    <nav class="site-nav">
        <div class="site-nav__inner">
            <a href="/" class="site-nav__brand">
                <img src="~/images/DraftView.Logo.web.png"
                     alt="DraftView"
                     class="site-nav__logo" />
                DraftView
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <button type="button"
                        class="nav-toggle"
                        id="navToggle"
                        aria-label="Open navigation menu"
                        aria-controls="navMenu"
                        aria-expanded="false">
                    @Icons.Menu()
                </button>

                <div class="site-nav__menu" id="navMenu">
                    <div class="site-nav__links">
                        @if (User.IsInRole("SystemSupport"))
                        {
                            <a asp-controller="Support" asp-action="Dashboard" class="site-nav__link">System Dashboard</a>
                        }
                        else if (User.IsInRole("Author"))
                        {
                            <a asp-controller="Author" asp-action="Dashboard" class="site-nav__link">Dashboard</a>
                            <a asp-controller="Reader" asp-action="Index" class="site-nav__link">Reader View</a>
                            <a asp-controller="Author" asp-action="Readers" class="site-nav__link">Readers</a>
                        }
                        else
                        {
                            <a asp-controller="Reader" asp-action="Dashboard" class="site-nav__link">My Reading</a>
                            <a asp-controller="Reader" asp-action="Index" class="site-nav__link">Browse</a>
                        }
                    </div>

                    <div class="site-nav__user">
                        <a asp-controller="Account"
                           asp-action="Settings"
                           class="site-nav__user-email"
                           title="Account settings">
                            @accountNavLabel
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="site-nav__logout">Sign out</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </nav>

    <!-- Toast notifications -->
    <div class="toast-container" id="toastContainer">
        @if (TempData["Success"] != null)
        {
            <div class="toast toast--success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast toast--error">@TempData["Error"]</div>
        }
    </div>

    <!-- Page content -->
    <main class="site-main">
        @RenderBody()
    </main>

    <!-- Footer (Desktop only) -->
    @if (Context.Request.Path.Value != null &&
                 !Context.Request.Path.Value.Contains("/Mobile", StringComparison.OrdinalIgnoreCase))
    {
        <footer class="site-footer">
            <div class="site-footer__inner">
                <div class="site-footer__left">
                    <a asp-controller="Home" asp-action="Privacy">Privacy Notice</a>
                </div>

                <div class="site-footer__centre">
                    <img src="~/images/DraftView.Logo.web.png"
                         alt="DraftView"
                         class="site-footer__logo" />
                    &emsp;
                    <span>&copy; @DateTime.Now.Year DraftView</span>
                </div>

                <div class="site-footer__right">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        DraftView.Domain.Entities.SystemStateMessage? sysMsg = null;
                        try
                        {
                            sysMsg = await SystemStateMessageService.GetActiveMessageAsync();
                        }
                        catch { }
                        @if (sysMsg is not null)
                        {
                            var severityClass = sysMsg.Severity switch {
                                DraftView.Domain.Enumerations.SystemStateMessageSeverity.Warning => "site-footer__status--warning",
                                DraftView.Domain.Enumerations.SystemStateMessageSeverity.Critical => "site-footer__status--critical",
                                _ => "site-footer__status--info"
                            };
                            <span class="site-footer__status @severityClass">@sysMsg.Message</span>
                        }
                        else
                        {
                            <span class="site-footer__status">System operational</span>
                        }
                    }
                </div>
            </div>
        </footer>
    }

    <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll('.toast').forEach(function(t) {
                    setTimeout(function() {
                        t.style.opacity = '0';
                        setTimeout(function() { t.remove(); }, 400);
                    }, 3000);
                });

                const navToggle = document.getElementById("navToggle");
                const navMenu = document.getElementById("navMenu");

                if (!navToggle || !navMenu) {
                    return;
                }

                navToggle.addEventListener("click", function () {
                    const isOpen = navMenu.classList.toggle("is-open");
                    navToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
                });

                window.addEventListener("resize", function () {
                    if (window.innerWidth > 768) {
                        navMenu.classList.remove("is-open");
                        navToggle.setAttribute("aria-expanded", "false");
                    }
                });
            });
    </script>

</body>
</html>
