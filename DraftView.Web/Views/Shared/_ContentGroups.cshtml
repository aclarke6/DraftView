@model IReadOnlyList<ContentGroup>

@foreach (var group in Model)
{
    var topSpace = group.Depth == 0 ? "20px" : "12px";
    var indent = $"{group.Depth * 16}px";
    var headingClass = group.Depth == 0
        ? "content-group__heading content-group__heading--root"
        : "content-group__heading content-group__heading--nested";

    <div class="content-group"
         style="--content-group-margin-top:@topSpace; --content-group-indent:@indent;">

        @if (!string.IsNullOrEmpty(group.Heading))
        {
            <h4 class="@headingClass">
                @group.Heading
            </h4>
        }

        @if (group.ChapterSection is not null)
        {
            <div class="content-group__chapter">
                <a asp-controller="Reader"
                   asp-action="Read"
                   asp-route-id="@group.ChapterSection.Id"
                   class="content-group__chapter-link">@group.ChapterSection.Title</a>
            </div>
        }

        @if (group.SubGroups.Any())
        {
            @await Html.PartialAsync("_ContentGroups", group.SubGroups)
        }
    </div>
}