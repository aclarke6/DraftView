@model IReadOnlyList<(DraftView.Domain.Entities.Section Section, int Depth)>
@{
    ViewData["Title"] = "Sections";
    var project     = ViewBag.Project as DraftView.Domain.Entities.Project;
    var publishable = ViewBag.Publishable as HashSet<Guid> ?? new HashSet<Guid>();
    var classificationMap = ViewBag.ClassificationMap as Dictionary<Guid, DraftView.Domain.Enumerations.ChangeClassification>
        ?? new Dictionary<Guid, DraftView.Domain.Enumerations.ChangeClassification>();

    // Build a set of folder IDs that contain at least one sub-folder child.
    // These are Parts/Books - they get no Publish button.
    // Chapters contain only Documents, so they are not in this set.
    var folderChildIds = Model
        .Where(i => i.Section.NodeType == NodeType.Folder && i.Section.ParentId.HasValue)
        .Select(i => i.Section.ParentId!.Value)
        .ToHashSet();
}

<h2>@project?.Name - Sections</h2>
<p><a asp-action="Dashboard">&larr; Back to Dashboard</a></p>
<p class="page-subtitle">
    Publish buttons appear on chapters where all scenes are First Draft or above.
    Publishing a chapter makes all its scenes visible to readers.
</p>

<script>
    (function () {
        if (history.scrollRestoration) history.scrollRestoration = 'manual';
        var hash = window.location.hash;
        if (hash) {
            setTimeout(function () {
                var el = document.querySelector(hash);
                if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }, 50);
        }
    })();
</script>

@if (project?.ProjectType == ProjectType.Manual)
{
    <div class="tree-builder__add-form">
        <form asp-action="CreateSection" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@project!.Id" />
            <input type="text" name="title" placeholder="Section title" class="input input--sm" required />
            <select name="nodeType" class="input input--sm">
                <option value="Document">Document</option>
                <option value="Folder">Chapter / Folder</option>
            </select>
            <select name="parentId" class="input input--sm">
                <option value="">— No parent (root) —</option>
                @foreach (var item in Model.Where(x => x.Section.NodeType == NodeType.Folder && !x.Section.IsSoftDeleted))
                {
                    <option value="@item.Section.Id">@item.Section.Title</option>
                }
            </select>
            <button type="submit" class="btn btn--primary btn--sm">Add Section</button>
        </form>
    </div>
}

@if (!Model.Any())
{
    <p>No sections found. Try syncing the project first.</p>
}
else
{
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Published</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var s        = item.Section;
                    var indent   = item.Depth * 20;
                    var isFolder = s.NodeType == NodeType.Folder;

                    // A chapter is a folder whose parent is NOT in folderChildIds
                    // (i.e. it doesn't contain sub-folders itself, only scenes)
                    var isChapter = isFolder && !folderChildIds.Contains(s.Id);

                    // Manual project documents need upload button
                    var isManualDocument = !isFolder && project?.ProjectType == ProjectType.Manual;

                    <tr class="@(isFolder ? "tr--folder" : "tr--scene")" id="section-@s.Id"
                        data-section-id="@(project?.ProjectType == ProjectType.Manual ? s.Id : null)"
                        data-draggable="@(project?.ProjectType == ProjectType.Manual ? "true" : null)"
                        data-project-id="@(project?.ProjectType == ProjectType.Manual ? project?.Id : null)"
                        data-parent-id="@(project?.ProjectType == ProjectType.Manual && s.ParentId.HasValue ? s.ParentId.Value : null)"
                        data-sort-order="@(project?.ProjectType == ProjectType.Manual ? s.SortOrder : 0)">
                        <td style="padding-left: @(8 + indent)px">
                            @if (!isFolder)
                            {
                                <a asp-action="Section" asp-route-id="@s.Id">@s.Title</a>
                            }
                            else
                            {
                                @s.Title
                            }
                        </td>
                        <td style="color:var(--color-text-muted); font-size:var(--text-sm)">
                            @(isChapter ? "Chapter" : isFolder ? "Part / Book" : "Scene")
                        </td>
                        <td>@(s.ScrivenerStatus ?? "-")</td>
                        <td>
                            @if (isChapter && s.IsPublished)
                            {
                                <span class="badge badge--success">Published</span>
                            }
                            else if (isChapter)
                            {
                                <span style="color:var(--color-text-subtle)">-</span>
                            }
                        </td>
                        <td>
                            @if (isChapter)
                            {
                                if (s.IsPublished)
                                {
                                    <form asp-action="UnpublishChapter" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="chapterId" value="@s.Id" />
                                        <input type="hidden" name="projectId" value="@project!.Id" />
                                        <button type="submit" class="btn btn--danger btn--sm">Unpublish</button>
                                    </form>

                                    @if (s.ContentChangedSincePublish)
                                    {
                                        if (classificationMap.TryGetValue(s.Id, out var classification))
                                        {
                                            <span class="change-indicator change-indicator--@classification.ToString().ToLower()">
                                                @classification
                                            </span>
                                        }

                                        <a asp-action="Publishing"
                                           asp-route-projectId="@project!.Id"
                                           class="btn btn--republish btn--sm">
                                            Publish changes
                                        </a>
                                    }
                                }
                                else if (publishable.Contains(s.Id))
                                {
                                    <form asp-action="PublishChapter" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="chapterId" value="@s.Id" />
                                        <input type="hidden" name="projectId" value="@project!.Id" />
                                        <button type="submit" class="btn btn--primary btn--sm">Publish</button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:var(--color-text-subtle); font-size:var(--text-xs)">Not ready</span>
                                }
                            }

                            @if (isManualDocument)
                            {
                                <a asp-action="UploadScene"
                                   asp-route-projectId="@project!.Id"
                                   asp-route-parentChapterId="@s.ParentId"
                                   class="btn btn--secondary btn--sm">
                                    Upload
                                </a>
                            }

                            @if (project?.ProjectType == ProjectType.Manual)
                            {
                                <form asp-action="DeleteSection" method="post" style="display:inline"
                                      onsubmit="return confirm('Delete this section and all descendants?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sectionId" value="@s.Id" />
                                    <input type="hidden" name="projectId" value="@project!.Id" />
                                    <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (project?.ProjectType == ProjectType.Manual)
{
    <script>
        // Tree builder drag-and-drop for Manual projects
        (function () {
            var rows = document.querySelectorAll('tr[data-section-id][data-draggable]');
            var draggedId = null;
            rows.forEach(function (row) {
                row.setAttribute('draggable', 'true');
                row.addEventListener('dragstart', function () { draggedId = row.dataset.sectionId; });
                row.addEventListener('dragover', function (e) { e.preventDefault(); });
                row.addEventListener('drop', function (e) {
                    e.preventDefault();
                    if (!draggedId || draggedId === row.dataset.sectionId) return;
                    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    fetch('/Author/MoveSection', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: 'sectionId=' + draggedId +
                              '&projectId=' + row.dataset.projectId +
                              '&newParentId=' + (row.dataset.parentId || '') +
                              '&newSortOrder=' + row.dataset.sortOrder +
                              '&__RequestVerificationToken=' + encodeURIComponent(token)
                    }).then(function (r) {
                        if (r.ok)
                            location.reload();
                    });
                });
            });
        })();
    </script>
}








