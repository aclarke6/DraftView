@model IReadOnlyList<DraftView.Domain.Interfaces.Services.DiscoveredProject>
@{
    ViewData["Title"] = "Add Project";
    var available = Model.Where(p => !p.AlreadyAdded).ToList();
    var added     = Model.Where(p => p.AlreadyAdded).ToList();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Project</h1>
        <p class="page-subtitle">Scanning: /Apps/Scrivener</p>
    </div>
</div>

<p><a asp-action="Dashboard">&larr; Back to Dashboard</a></p>

@if (!Model.Any())
{
    <div class="card">
        <div class="card__body" style="text-align:center; padding:var(--space-10);">
            <p class="ss-text-muted">No projects found in your Dropbox vault.</p>
        </div>
    </div>
}
else
{
    <form asp-action="AddProjects" method="post" id="addProjectsForm">
        @Html.AntiForgeryToken()

        <div style="display:grid; grid-template-columns:1fr auto 1fr; gap:var(--space-4); align-items:start; margin-bottom:var(--space-6);">

            <!-- Available list -->
            <div class="card">
                <div class="card__header">
                    <span class="card__title">Available</span>
                    <span style="font-size:var(--text-sm); color:var(--color-ink-muted);">@available.Count vault(s)</span>
                </div>
                <div id="availableList" style="min-height:120px; padding:var(--space-2);">
                    @foreach (var p in available)
                    {
                        <div class="project-item" data-uuid="@p.ScrivenerRootUuid" data-name="@p.Name" data-vault="@System.IO.Path.GetFileName(p.DropboxPath)"
                             style="display:flex; justify-content:space-between; align-items:center; padding:var(--space-3) var(--space-4); border-radius:6px; margin-bottom:var(--space-2); background:var(--color-surface); border:1px solid var(--color-border); cursor:pointer;"
                             onclick="moveToSelected(this)">
                            <div>
                                <div style="font-weight:500; font-size:var(--text-sm);">@p.Name</div>
                                <div style="font-size:0.75rem; color:var(--color-ink-muted);">@System.IO.Path.GetFileName(p.DropboxPath)</div>
                            </div>
                            <span style="color:var(--color-accent); font-size:1.1em;">&rsaquo;</span>
                        </div>
                    }
                    @if (!available.Any())
                    {
                        <p style="color:var(--color-ink-muted); font-size:var(--text-sm); padding:var(--space-4); text-align:center;">
                            All projects already added
                        </p>
                    }
                </div>
            </div>

            <!-- Arrow buttons -->
            <div style="display:flex; flex-direction:column; gap:var(--space-2); padding-top:60px;">
                <button type="button" onclick="moveAllToSelected()"
                        class="btn btn--secondary btn--sm" title="Add all">&raquo;</button>
                <button type="button" onclick="moveAllToAvailable()"
                        class="btn btn--secondary btn--sm" title="Remove all">&laquo;</button>
            </div>

            <!-- Selected list -->
            <div class="card">
                <div class="card__header">
                    <span class="card__title">To Add</span>
                    <span id="selectedCount" style="font-size:var(--text-sm); color:var(--color-ink-muted);">0 selected</span>
                </div>
                <div id="selectedList" style="min-height:120px; padding:var(--space-2);">
                    <p id="emptySelectedMsg" style="color:var(--color-ink-muted); font-size:var(--text-sm); padding:var(--space-4); text-align:center;">
                        Click projects on the left to add them
                    </p>
                </div>
            </div>
        </div>

        <!-- Already added (read-only) -->
        @if (added.Any())
        {
            <div class="card" style="margin-bottom:var(--space-6);">
                <div class="card__header">
                    <span class="card__title">Already Added</span>
                </div>
                <div style="padding:var(--space-2);">
                    @foreach (var p in added)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:var(--space-3) var(--space-4); border-radius:6px; margin-bottom:var(--space-2); background:var(--color-surface); border:1px solid var(--color-border); opacity:0.6;">
                            <div>
                                <div style="font-weight:500; font-size:var(--text-sm);">@p.Name</div>
                                <div style="font-size:0.75rem; color:var(--color-ink-muted);">@System.IO.Path.GetFileName(p.DropboxPath)</div>
                            </div>
                            <span style="color:var(--color-success); font-size:var(--text-sm);">&#10003; Added</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Hidden inputs populated by JS -->
        <div id="hiddenInputs"></div>

        <div style="display:flex; gap:var(--space-3); align-items:center;">
            <button type="submit" class="btn btn--primary" id="submitBtn" disabled>Add Selected</button>
            <a asp-action="Dashboard" class="btn btn--secondary">Cancel</a>
        </div>
    </form>
}

<script>
    function moveToSelected(el) {
        el.onclick = null;
        el.querySelector('span').innerHTML = '&lsaquo;';
        el.querySelector('span').style.color = 'var(--color-danger)';
        el.onclick = function() { moveToAvailable(el); };
        document.getElementById('selectedList').appendChild(el);
        updateState();
    }

    function moveToAvailable(el) {
        el.onclick = null;
        el.querySelector('span').innerHTML = '&rsaquo;';
        el.querySelector('span').style.color = 'var(--color-accent)';
        el.onclick = function() { moveToSelected(el); };
        document.getElementById('availableList').appendChild(el);
        updateState();
    }

    function moveAllToSelected() {
        const items = [...document.getElementById('availableList').querySelectorAll('.project-item')];
        items.forEach(el => moveToSelected(el));
    }

    function moveAllToAvailable() {
        const items = [...document.getElementById('selectedList').querySelectorAll('.project-item')];
        items.forEach(el => moveToAvailable(el));
    }

    function updateState() {
        const selected = document.getElementById('selectedList').querySelectorAll('.project-item');
        const available = document.getElementById('availableList').querySelectorAll('.project-item');

        // Update count
        document.getElementById('selectedCount').textContent = selected.length + ' selected';

        // Toggle empty message
        document.getElementById('emptySelectedMsg').style.display =
            selected.length === 0 ? 'block' : 'none';

        // Enable/disable submit
        document.getElementById('submitBtn').disabled = selected.length === 0;

        // Rebuild hidden inputs
        const container = document.getElementById('hiddenInputs');
        container.innerHTML = '';
        selected.forEach(el => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'selectedUuids';
            input.value = el.dataset.uuid;
            container.appendChild(input);
        });
    }

    // Init
    updateState();
</script>
