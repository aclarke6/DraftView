@using DraftView.Web.Infrastructure
@using DraftView.Web.Models
@model IReadOnlyList<ReaderRowViewModel>
@{ ViewData["Title"] = "Beta Readers"; }

<div class="page-header">
    <div>
        <h1 class="page-title">Beta Readers</h1>
        <p class="page-subtitle">@Model.Count reader(s)</p>
    </div>
    <a asp-action="InviteReader" class="btn btn--primary">Invite a Reader</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state__title">No readers yet</div>
        <p class="empty-state__body">Invite your first beta reader to get started.</p>
    </div>
}
else
{
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="ManageReaderAccess" asp-route-readerId="@r.Id"
                               style="font-weight: var(--font-medium);">@r.DisplayName</a>
                        </td>
                        <td style="color:var(--color-text-muted);">@r.Email</td>
                        <td>
                            @switch (r.Status)
                            {
                                case ReaderStatus.Active:
                                    <span class="badge badge--success">Active</span>
                                    break;
                                case ReaderStatus.Invited:
                                    <span class="badge badge--neutral">Invited</span>
                                    break;
                                default:
                                    <span class="badge badge--neutral">Inactive</span>
                                    break;
                            }
                        </td>
                        <td style="color:var(--color-text-muted); font-size:var(--text-sm);">
                            @(r.ActivatedAt.HasValue ? r.ActivatedAt.Value.ToString("dd MMM yyyy") : "-")
                        </td>
                        <td>
                            <div class="actions-cell">
                                @if (r.Status == ReaderStatus.Active)
                                {
                                    <form asp-action="DeactivateReader" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@r.Id" />
                                        <button type="submit" class="comment-action-btn comment-action-btn--danger"
                                                title="Deactivate reader">@Html.Raw(Icons.NoSymbol())</button>
                                    </form>
                                }
                                else if (r.Status == ReaderStatus.Inactive)
                                {
                                    <form asp-action="ReactivateReader" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@r.Id" />
                                        <button type="submit" class="comment-action-btn"
                                                title="Reactivate reader">@Html.Raw(Icons.Restore())</button>
                                    </form>
                                }
                                <form asp-action="SoftDeleteReader" method="post"
                                      onsubmit="return confirm('Remove @r.DisplayName from your readers list?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@r.Id" />
                                    <button type="submit" class="comment-action-btn comment-action-btn--danger"
                                            title="Remove reader">@Html.Raw(Icons.Delete())</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}


