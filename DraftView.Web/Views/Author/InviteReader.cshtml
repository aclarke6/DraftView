@model InviteReaderViewModel
@{
    ViewData["Title"] = "Invite Reader";
}

<div class="page-header">
    <h1 class="page-title">Invite a Reader</h1>
    <p class="page-subtitle">An email will be sent with a link to create their account.</p>
</div>

<div class="card" style="max-width: 520px;">
    <div class="card__body">
        <form asp-action="InviteReader" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="form-error"></div>

            <div class="form-group">
                <label asp-for="Email">Email address</label>
                <input asp-for="Email" type="email" />
            </div>

            <div class="form-group">
                <label class="checkbox-label">
                    <input asp-for="NeverExpires" id="neverExpires" />
                    Invitation never expires
                </label>
                <div class="form-hint">Untick to set an expiry date.</div>
            </div>

            <div class="form-group" id="expiryBlock">
                <label asp-for="ExpiresAt">Expiry date</label>
                <input asp-for="ExpiresAt" type="datetime-local" />
            </div>

            <div style="display:flex; gap:12px;">
                <button type="submit" class="btn btn--primary">Send Invitation</button>
                <a asp-action="Readers" class="btn btn--secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    (function () {
        const checkbox = document.getElementById("neverExpires");
        const block = document.getElementById("expiryBlock");

        function update() {
            block.style.display = checkbox.checked ? "none" : "block";
        }

        checkbox.addEventListener("change", update);
        update();
    })();
</script>