@using DraftView.Domain.Enumerations
@model SectionViewModel
@{ ViewData["Title"] = Model.Section.Title; }

<div class="author-section-view">
    @if (Model.ChapterTitle is not null)
    {
        <p class="author-section-view__breadcrumb">
            <a asp-action="Sections" class="author-section-view__breadcrumb-link">Sections</a>
            <span class="author-section-view__breadcrumb-sep">&rsaquo;</span>
            <span>@Model.ChapterTitle</span>
        </p>
    }

    <h2 class="author-section-view__title">@Model.Section.Title</h2>
    <p class="author-section-view__meta">
        <span>@(Model.Section.ScrivenerStatus ?? "-")</span>
        <span class="author-section-view__meta-sep">|</span>
        <span>Read by @Model.ReadCount reader(s)</span>
    </p>

    <div class="card author-section-view__content-card">
        <div class="card__body">
            <div class="author-section-view__prose">
                @Html.Raw(Model.Section.HtmlContent ?? "<p><em>No content.</em></p>")
            </div>
        </div>
    </div>

    <h3 class="author-section-view__comments-heading">Comments (@Model.Comments.Count)</h3>

    @foreach (var c in Model.Comments)
    {
        var authorName = Model.CommentAuthorNames.TryGetValue(c.AuthorId, out var n) ? n : "Unknown";
        var isAuthorReply = c.Status == CommentStatus.AuthorReply;
        var isReply = c.ParentCommentId.HasValue;
        var commentClasses = "author-section-comment";

        if (isReply)
            commentClasses += " author-section-comment--reply";

        if (c.Visibility == Visibility.Private)
            commentClasses += " author-section-comment--private";

        <div class="@commentClasses">
            <div class="author-section-comment__header">
                <div class="author-section-comment__meta">
                    <strong class="author-section-comment__author">@authorName</strong>
                    @if (c.Visibility == Visibility.Private)
                    {
                        <span class="author-section-comment__private">[Private]</span>
                    }
                    <span class="author-section-comment__date">@c.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                </div>

                @if (isAuthorReply)
                {
                    <span class="author-section-comment__author-reply">Author reply</span>
                }
                else if (!isReply)
                {
                    <form asp-action="SetCommentStatus" method="post" class="author-section-comment__status-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="commentId" value="@c.Id" />
                        <input type="hidden" name="sectionId" value="@Model.Section.Id" />
                        <select name="status" onchange="this.form.submit()"
                                class="author-section-comment__status-select @StatusClass(c.Status)">
                            @foreach (var s in Enum.GetValues<CommentStatus>().Where(s => s != CommentStatus.AuthorReply))
                            {
                                <option value="@s" selected="@(c.Status == s)">@s</option>
                            }
                        </select>
                    </form>
                }
            </div>

            @if (c.IsSoftDeleted)
            {
                <p class="author-section-comment__deleted">This comment has been removed.</p>
            }
            else
            {
                <p class="author-section-comment__body">@c.Body</p>
                <details class="author-section-comment__reply-details">
                    <summary class="author-section-comment__reply-summary">
                        @Icons.Reply() Reply
                    </summary>
                    <form asp-action="ReplyToComment" method="post" class="author-section-comment__reply-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="parentCommentId" value="@c.Id" />
                        <input type="hidden" name="sectionId" value="@Model.Section.Id" />
                        <textarea name="body" rows="3" placeholder="Your reply..." class="author-section-comment__reply-input"></textarea>
                        <div class="author-section-comment__reply-actions">
                            <button type="submit" class="btn btn--primary btn--sm">@Icons.Reply()</button>
                        </div>
                    </form>
                </details>
            }
        </div>
    }

    @if (!Model.Comments.Any())
    {
        <p class="author-section-view__comments-empty">No comments on this section yet.</p>
    }
</div>

@functions {
    static string StatusClass(CommentStatus status) => status switch
    {
        CommentStatus.New => "author-section-comment__status-select--new",
        CommentStatus.Todo => "author-section-comment__status-select--todo",
        CommentStatus.Consider => "author-section-comment__status-select--consider",
        CommentStatus.Done => "author-section-comment__status-select--done",
        CommentStatus.Ignore => "author-section-comment__status-select--ignore",
        CommentStatus.Keep => "author-section-comment__status-select--keep",
        _ => string.Empty
    };
}

