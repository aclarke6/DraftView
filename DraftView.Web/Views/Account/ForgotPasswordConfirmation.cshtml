@{ ViewData["Title"] = "Check your email"; }
<div class="login-wrap">
    <div class="login-header">
        <h1>Check your email</h1>
    </div>
    <div class="card">
        <div class="card__body" style="text-align:center; padding:var(--space-8);">
            <div class="ornament">&#10022;</div>
            <p style="color:var(--color-ink-muted); margin-bottom:var(--space-4);">
                If that email address is registered, you will receive a password
                reset link shortly.
            </p>
            <p style="font-size:var(--text-sm); color:var(--color-ink-subtle);">
                The link expires after 24 hours.
            </p>
        </div>
    </div>
    <div style="text-align:center; margin-top:var(--space-5);">
        <a asp-action="Login" style="font-size:var(--text-sm);">Back to sign in</a>
    </div>
</div>
