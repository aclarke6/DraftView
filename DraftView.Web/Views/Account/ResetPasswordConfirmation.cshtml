@{ ViewData["Title"] = "Password reset"; }
<div class="login-wrap">
    <div class="login-header">
        <h1>Password reset</h1>
    </div>
    <div class="card">
        <div class="card__body" style="text-align:center; padding:var(--space-8);">
            <div class="ornament">&#10022;</div>
            <p style="color:var(--color-ink-muted); margin-bottom:var(--space-6);">
                Your password has been reset successfully.
            </p>
            <a asp-action="Login" class="btn btn--primary">Sign in</a>
        </div>
    </div>
</div>
