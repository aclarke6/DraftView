@model DraftView.Web.Models.SettingsViewModel
@{ ViewData["Title"] = "Account Settings"; }

<div class="page-header">
    <h1 class="page-title">Account Settings</h1>
</div>

<div class="card" style="max-width:560px; margin-bottom:var(--space-6);">
    <div class="card__header"><span class="card__title">Display Name</span></div>
    <div class="card__body">
        <form asp-action="ChangeDisplayName" method="post">
            @Html.AntiForgeryToken()
            <div style="display:flex; gap:var(--space-3); align-items:flex-end;">
                <div style="flex:1;">
                    <label class="form-label">Display name</label>
                    <input type="text" name="DisplayName" value="@Model.DisplayName" class="form-input" required />
                </div>
                <button type="submit" class="btn btn--primary">Save</button>
            </div>
        </form>
    </div>
</div>

<div class="card" style="max-width:560px; margin-bottom:var(--space-6);">
    <div class="card__header"><span class="card__title">Email Address</span></div>
    <div class="card__body">
        <form asp-action="ChangeEmail" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:var(--space-4);">
                <label class="form-label">New email address</label>
                <input type="email" name="Email" value="@Model.Email" class="form-input" required />
            </div>
            <div style="margin-bottom:var(--space-4);">
                <label class="form-label">Current password (to confirm)</label>
                <input type="password" name="CurrentPassword" class="form-input" required />
            </div>
            <button type="submit" class="btn btn--primary">Update Email</button>
        </form>
    </div>
</div>

<div class="card" style="max-width:560px; margin-bottom:var(--space-6);">
    <div class="card__header"><span class="card__title">Change Password</span></div>
    <div class="card__body">
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:var(--space-4);">
                <label class="form-label">Current password</label>
                <input type="password" name="CurrentPassword" class="form-input" required />
            </div>
            <div style="margin-bottom:var(--space-4);">
                <label class="form-label">New password</label>
                <input type="password" name="NewPassword" class="form-input" required />
            </div>
            <div style="margin-bottom:var(--space-4);">
                <label class="form-label">Confirm new password</label>
                <input type="password" name="ConfirmPassword" class="form-input" required />
            </div>
            <button type="submit" class="btn btn--primary">Change Password</button>
        </form>
    </div>
</div>

@if (Model.IsAuthor)
{
    <div class="card" style="max-width:560px;">
        <div class="card__header"><span class="card__title">Dropbox</span></div>
        <div class="card__body">
            @if (Model.DropboxStatus == "Connected")
            {
                <p style="margin-bottom:var(--space-4);">
                    <span class="badge badge--success">Connected</span>
                    @if (Model.DropboxAuthorisedAt.HasValue)
                    {
                        <span style="color:var(--color-ink-muted); font-size:var(--text-sm); margin-left:var(--space-2);">
                            since @Model.DropboxAuthorisedAt.Value.ToString("dd MMM yyyy")
                        </span>
                    }
                </p>
                <div style="display:flex; gap:var(--space-3);">
                    <a asp-controller="Dropbox" asp-action="Connect" class="btn btn--secondary">Reconnect</a>
                    <form asp-controller="Dropbox" asp-action="Disconnect" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn--danger">Disconnect</button>
                    </form>
                </div>
            }
            else
            {
                <p style="margin-bottom:var(--space-4); color:var(--color-ink-muted);">
                    <span class="badge badge--neutral">Not connected</span>
                </p>
                <a asp-controller="Dropbox" asp-action="Connect" class="btn btn--primary">Connect Dropbox</a>
            }
        </div>
    </div>
}
