@{ ViewData["Title"] = "Link expired"; }
<div class="login-wrap">
    <div class="login-header">
        <h1>Link expired</h1>
    </div>
    <div class="card">
        <div class="card__body" style="text-align:center; padding:var(--space-8);">
            <div class="ornament">&#10022;</div>
            <p style="color:var(--color-ink-muted); margin-bottom:var(--space-6);">
                This password reset link has expired or has already been used.
            </p>
            <a asp-action="ForgotPassword" class="btn btn--primary">Request a new link</a>
        </div>
    </div>
</div>
