@{
    ViewData["Title"] = "Privacy Notice";
}

<div class="page-header">
    <h1 class="page-title">Privacy Notice</h1>
    <p class="page-subtitle">How DraftView uses and protects account email addresses.</p>
</div>

<div class="settings-page">
    <div class="settings-layout">
        <div class="settings-layout__main">
            <div class="card settings-card">
                <div class="card__header"><span class="card__title">What we use email for</span></div>
                <div class="card__body">
                    <p>DraftView uses your email address only for service-related communication such as sign-in, invitations, password reset, and account support.</p>
                </div>
            </div>

            <div class="card settings-card">
                <div class="card__header"><span class="card__title">What we do not do</span></div>
                <div class="card__body">
                    <p>DraftView does not use account email addresses for marketing.</p>
                    <p>DraftView does not share account email addresses with third parties for unrelated purposes.</p>
                </div>
            </div>
        </div>

        <div class="settings-layout__side">
            <div class="card settings-card">
                <div class="card__header"><span class="card__title">Protection and access</span></div>
                <div class="card__body">
                    <p>Email addresses are protected by design, restricted to explicit application flows, and not exposed to other users beyond approved self-service views.</p>
                    <p>Administrative access is controlled and auditable.</p>
                </div>
            </div>

            <div class="card settings-card">
                <div class="card__header"><span class="card__title">Data protection basis</span></div>
                <div class="card__body">
                    <p>DraftView is intended to handle account email data in line with UK GDPR principles of data minimisation, access control, and protection by design, together with the Data Protection Act 2018.</p>
                </div>
            </div>
        </div>
    </div>
</div>
